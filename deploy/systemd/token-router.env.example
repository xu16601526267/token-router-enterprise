# Copy to /etc/token-router/token-router.env and set real values.
# Do not commit a populated env file.

# API process
PORT=19090
SQLITE_PATH=/var/lib/token-router/token-router.db
MEMORY_CACHE_ENABLED=true
NODE_NAME=dedicated-01
GIN_MODE=release

# Runner connection
TOKEN_ROUTER_API_BASE=http://127.0.0.1:19090
TOKEN_ROUTER_ADMIN_TOKEN=change-me
TOKEN_ROUTER_HOSTNAME=dedicated-01
TOKEN_ROUTER_DEPLOY_VERSION=manual

# Supply telemetry runner defaults
TOKEN_ROUTER_TELEMETRY_AGENT_KEY=dedicated-01:telemetry
TOKEN_ROUTER_TELEMETRY_INTERVAL=5m
TOKEN_ROUTER_TELEMETRY_MIN_COLLECTED=0
TOKEN_ROUTER_TELEMETRY_FAIL_ON_SKIP=false
TOKEN_ROUTER_TELEMETRY_SUPPLIER_ID=0
TOKEN_ROUTER_TELEMETRY_CHANNEL_ID=0
TOKEN_ROUTER_TELEMETRY_SUPPLY_NODE=
TOKEN_ROUTER_TELEMETRY_MODEL=

# Operations review runner defaults
TOKEN_ROUTER_REVIEW_AGENT_KEY=dedicated-01:review
TOKEN_ROUTER_REVIEW_INTERVAL=15m
TOKEN_ROUTER_REVIEW_MIN_GENERATED=1
TOKEN_ROUTER_REVIEW_SUPPLIER_ID=0
TOKEN_ROUTER_REVIEW_MODEL=
TOKEN_ROUTER_REVIEW_SLA_TIER=
TOKEN_ROUTER_REVIEW_USER_ID=0
